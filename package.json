{
  "name": "primeta",
  "displayName": "Primeta",
  "description": "3D VRM avatar overlay with TTS lip-sync for Claude Code",
  "version": "0.2.0",
  "publisher": "PrimetaAI",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/Primeta-AI/vscode-primeta-extension.git"
  },
  "bugs": {
    "url": "https://github.com/Primeta-AI/vscode-primeta-extension/issues"
  },
  "homepage": "https://primeta.ai",
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "avatar",
    "vrm",
    "tts",
    "mcp"
  ],
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": ["Other"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "primeta.showPersona",
        "title": "Primeta: Show Persona"
      },
      {
        "command": "primeta.hidePersona",
        "title": "Primeta: Hide Persona"
      },
      {
        "command": "primeta.setApiToken",
        "title": "Primeta: Set API Token"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "primeta",
          "title": "Primeta",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "views": {
      "primeta": [
        {
          "id": "primeta.home",
          "name": "Primeta",
          "contextualTitle": "Primeta",
          "icon": "assets/sidebar-icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "primeta.home",
        "when": "!primeta.hasApiToken",
        "contents": "A 3D avatar companion for Claude Code — watch your assistant speak and emote as you work.\n\nTo get started, copy your API token from the [primeta.ai settings page](https://primeta.ai/settings) and paste it here.\n\n[Set API Token](command:primeta.setApiToken)"
      },
      {
        "view": "primeta.home",
        "when": "primeta.hasApiToken",
        "contents": "Open your persona to see your AI assistant come to life.\n\n[Show Persona](command:primeta.showPersona)\n[Hide Persona](command:primeta.hidePersona)\n\nPrimeta auto-connects to a Claude Code bridge matching your workspace folder name. If none is running, [set up the MCP bridge](https://primeta.ai/docs/mcp).\n\n[Change API Token](command:primeta.setApiToken)\n\nNeed a new token? Get one from your [primeta.ai settings page](https://primeta.ai/settings)."
      }
    ],
    "configuration": {
      "title": "Primeta",
      "properties": {
        "primeta.serverUrl": {
          "type": "string",
          "default": "https://primeta.ai",
          "description": "Primeta server URL"
        },
        "primeta.apiToken": {
          "type": "string",
          "default": "",
          "description": "API token (from Primeta Settings page)"
        }
      }
    }
  },
  "scripts": {
    "build": "npm run build:ext && npm run build:webview",
    "build:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap",
    "build:webview": "esbuild webview/avatar-renderer.js --bundle --outfile=dist/webview.js --format=iife --platform=browser --sourcemap --define:global=globalThis",
    "watch": "npm run watch:ext & npm run watch:webview",
    "watch:ext": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --sourcemap --watch",
    "watch:webview": "esbuild webview/avatar-renderer.js --bundle --outfile=dist/webview.js --format=iife --platform=browser --sourcemap --define:global=globalThis --watch",
    "package": "npm run build && vsce package"
  },
  "dependencies": {
    "@primeta/persona-core": "file:./vendor/persona-core",
    "three": "^0.170.0",
    "@pixiv/three-vrm": "^3.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  }
}
